# Copy to jashfin-backend/.env for local development.

DJANGO_DEBUG=1
# DJANGO_SECRET_KEY=only-required-when-DJANGO_DEBUG=0

# Production (Railway): comma-separated, no spaces (or minimal)
# ALLOWED_HOSTS=web-production-xxxx.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://web-production-xxxx.up.railway.app

# Railway injects this when Postgres is attached:
# DATABASE_URL=postgres://...

# If Postgres rejects SSL (rare locally), try:
# DATABASE_SSL_REQUIRE=false
